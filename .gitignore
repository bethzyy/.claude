# 可执行文件
*.exe
*.app
*.out

# Python
__pycache__/
*.py[cod]
venv/
.venv

# Node.js
node_modules/

# 日志
*.log
logs/

# 临时文件
*.tmp
*.bak
.DS_Store
Thumbs.db

